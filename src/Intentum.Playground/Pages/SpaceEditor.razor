@page "/space"
@using Intentum.Core.Behavior
@using System.Text.Json
@inject PlaygroundService Service

<PageTitle>BehaviorSpace Editor</PageTitle>

<h1>BehaviorSpace Editor</h1>

<EventEditor OnEventAdded="AddEvent" />

<div class="events-list">
    <h3>Events (@Service.Space.Events.Count)</h3>
    @foreach (var evt in Service.Space.Events)
    {
        <div class="event-item">
            <span>@evt.Actor:@evt.Action</span>
            <span>@evt.OccurredAt.ToString("HH:mm:ss")</span>
        </div>
    }
</div>

<div class="vector-output">
    <h3>Vector</h3>
    <pre>@JsonSerializer.Serialize(Service.Space.ToVector().Dimensions)</pre>
</div>

@code {
    private void AddEvent(BehaviorEvent evt)
    {
        Service.AddEvent(evt);
    }
}
