@using Intentum.Runtime.Policy

<div class="rule-editor">
    <input @bind="RuleName" placeholder="Rule name" />
    <select @bind="SelectedConfidenceLevel">
        <option value="Low">Low</option>
        <option value="Medium">Medium</option>
        <option value="High">High</option>
        <option value="Certain">Certain</option>
    </select>
    <select @bind="SelectedDecision">
        @foreach (var decision in Enum.GetValues<PolicyDecision>())
        {
            <option value="@decision">@decision</option>
        }
    </select>
    <button @onclick="AddRule" disabled="@string.IsNullOrWhiteSpace(RuleName)">Add Rule</button>
</div>

@code {
    private string RuleName { get; set; } = "";
    private string SelectedConfidenceLevel { get; set; } = "High";
    private PolicyDecision SelectedDecision { get; set; } = PolicyDecision.Allow;

    [Parameter]
    public EventCallback<PolicyRule> OnRuleAdded { get; set; }

    private async Task AddRule()
    {
        if (!string.IsNullOrWhiteSpace(RuleName))
        {
            var rule = new PolicyRule(RuleName, i => i.Confidence.Level == SelectedConfidenceLevel, SelectedDecision);
            await OnRuleAdded.InvokeAsync(rule);
            RuleName = "";
            SelectedConfidenceLevel = "High";
            SelectedDecision = PolicyDecision.Allow;
        }
    }
}
