@page "/Error"
@using System.Diagnostics
@layout MainLayout

<PageTitle>Hata</PageTitle>

<div class="page-card">
    <h1 class="text-danger">Hata</h1>
    <h2 class="text-danger" style="font-size: 1.1rem;">İsteğiniz işlenirken bir hata oluştu.</h2>

    @if (ShowRequestId)
    {
        <p class="muted">
            <strong>Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <p><NavLink href="" class="action-btn" style="display:inline-block; margin-top:0.5rem;">Ana sayfaya dön</NavLink></p>
</div>

<div class="page-card muted" style="font-size: 0.9rem;">
    <h3>Geliştirme modu</h3>
    <p><strong>Development</strong> ortamında hata ayrıntıları gösterilir. Dağıtılan uygulamalarda açık bırakmayın. Yerel debug için <strong>ASPNETCORE_ENVIRONMENT=Development</strong> ayarlayıp uygulamayı yeniden başlatın.</p>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
