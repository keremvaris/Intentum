@page "/moderation"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Moderation</PageTitle>

<div class="page-card">
    <h2 class="page-card h2" style="margin: 0 0 0.25rem 0;">Context Guardian: İçerik Moderasyonu Niyet Katmanı</h2>
    <p class="subtitle">Forum thread'inde mesaj dizisinden bağlamsal niyet (trolling, konudan sapma, yardım arayan); kişiselleştirilmiş uyarı.</p>
</div>

<div class="page-card commerce-5n1k">
    <h3 class="page-card h3" style="margin: 0 0 0.75rem 0;">Bu demo ne anlama geliyor? (5N1K) <InfoIcon Text="İçerik moderasyonu use case'ini kısa cevaplarla özetler." /></h3>
    <ul class="commerce-5n1k-list">
        <li><strong>Ne:</strong> Mesaj/thread dizisinden bağlamsal niyet çıkarımı (trolling, konudan sapma, yardım arayan); kişiselleştirilmiş uyarı veya moderatör yönlendirmesi.</li>
        <li><strong>Neden:</strong> Bilinen kötü içeriği kurallarla hızlı tespit etmek; belirsiz içerik için AI fallback ile niyet sınıflandırması.</li>
        <li><strong>Nerede:</strong> Forum, sosyal medya, topluluk platformlarında; mesaj veya thread işlendikten sonra Intentum'a gider.</li>
        <li><strong>Ne zaman:</strong> Yeni mesaj gönderildiğinde veya thread periyodik taranırken; moderatör kuyruğuna öncelik vermek için.</li>
        <li><strong>Nasıl:</strong> Kurallarla bilinen pattern'ler (küfür listesi, spam) → eşleşmezse AI ile niyet çıkar → Karar (Allow / Warn / Escalate).</li>
        <li><strong>Kim:</strong> Sosyal medya platformları, forum/topluluk yöneticileri.</li>
    </ul>
    <p class="muted" style="margin-top: 0.75rem; font-size: 0.9rem;"><strong>Hedef kitle:</strong> Sosyal medya, forum, topluluk. <strong>Gelir modeli:</strong> API bazlı faturalandırma.</p>
</div>

<div class="page-card">
    <h3 class="page-card h3" style="margin: 0 0 0.5rem 0;">Bu akışta Intentum nerede? <InfoIcon Text="Mesajlar gelir; kurallarla bilinen kötü içerik elenir; belirsiz olanlar Intentum ile niyet çıkarımına gider; karar moderatöre veya kullanıcıya uyarı olarak döner." /></h3>
    <p class="muted" style="margin: 0;">Mesaj/thread → <strong>[Kural: bilinen kötü içerik]</strong> → eşleşmezse <strong>[Intentum: niyet + güven]</strong> → Allow / Warn / Escalate (moderatör önceliği).</p>
</div>

<div class="page-card">
    <div class="project-pulse-controls">
        <div class="project-pulse-variants">
            <span class="project-pulse-label">Varyant:</span>
            @foreach (var v in new[] { "A", "B", "C", "D" })
            {
                <button type="button" class="btn-variant @(_selectedVariant == v ? "btn-variant--active" : "")" @onclick="() => SelectVariant(v)" title="@ModerationVariants.GetDescription(v)">
                    @v: @ModerationVariants.GetLabel(v)
                </button>
            }
        </div>
        <button type="button" class="btn-demo-insider" @onclick="RunInfer" disabled="@_running">
            @(_running ? "Çalışıyor…" : "Niyet Çıkar")
        </button>
    </div>
    <p class="muted" style="margin: 0.5rem 0 0; font-size: 0.9rem;">Varyantların üzerine gelerek kısa açıklamayı görebilirsiniz. Niyet Çıkar sonrası örnek uyarı metni ve «Sonraki N mesaj izlensin» çıktısı aşağıda gösterilir.</p>
</div>

@if (_result != null)
{
    <div class="page-card">
        <h3 class="page-card h3" style="margin: 0 0 0.75rem 0;">Özet (KPI)</h3>
        <div class="kpi-grid fraud-kpi-grid">
            <div class="card kpi-card kpi-card--metric">
                <span class="kpi-card__label">Niyet</span>
                <span class="kpi-card__value kpi-card__value--text">@_result.IntentName</span>
            </div>
            <div class="card kpi-card kpi-card--risk @ConfidenceClass(_result.ConfidenceScore)">
                <span class="kpi-card__label">Güven</span>
                <span class="kpi-card__value">@_result.ConfidenceScore.ToString("P0")</span>
            </div>
            <div class="card kpi-card kpi-card--metric">
                <span class="kpi-card__label">Karar</span>
                <span class="kpi-card__value kpi-card__value--text">
                    <span class="decision-badge decision-badge--@(_result.Decision.ToLowerInvariant())">@_result.Decision</span>
                </span>
            </div>
            <div class="card kpi-card kpi-card--metric">
                <span class="kpi-card__label">Sonraki izleme</span>
                <span class="kpi-card__value">@_result.ObserveNextCount <span class="kpi-card__unit">mesaj</span></span>
            </div>
        </div>
    </div>
    <div class="page-card">
        <h3 class="page-card h3" style="margin: 0 0 0.75rem 0;">Güven skoru ve mesaj sayısı</h3>
        <div class="fraud-charts-grid">
            <div class="fraud-chart-card card">
                <h3 class="fraud-chart-card__title">Güven skoru</h3>
                <div id="moderation-gauge" class="fraud-gauge"></div>
            </div>
            <div class="fraud-chart-card card fraud-chart-card--wide">
                <h3 class="fraud-chart-card__title">Thread özeti</h3>
                <div id="moderation-bar" class="fraud-line-chart"></div>
            </div>
        </div>
    </div>
    <div class="page-card">
        <h3 class="page-card h3" style="margin: 0 0 0.75rem 0;">Thread zaman çizelgesi</h3>
        <ul class="project-pulse-event-list">
            @foreach (var s in _result.EventsSummary)
            {
                <li class="project-pulse-event-item moderation-event-item">
                    <span class="project-pulse-event-summary">@s</span>
                </li>
            }
        </ul>
        <div class="project-pulse-result insider-result">
            <p><strong>Niyet:</strong> @_result.IntentName</p>
            <p><strong>Güven:</strong> @_result.ConfidenceScore.ToString("P0") (@_result.ConfidenceLevel)</p>
            <p><strong>Karar:</strong> <span class="decision-badge decision-badge--@(_result.Decision.ToLowerInvariant())">@_result.Decision</span></p>
            <p><strong>Sonraki izleme:</strong> @(_result.ObserveNextCount > 0 ? $"{_result.ObserveNextCount} mesaj moderatöre öncelikli izlensin." : "Ek izleme yok.")</p>
        </div>
        <div class="insider-warn-banner moderation-warning-bubble" style="margin-top: 0.75rem;">
            <strong>Örnek uyarı metni (kullanıcıya gösterilecek):</strong><br />
            @(string.IsNullOrEmpty(_result.WarningMessageTemplate) ? "— Bu varyant için uyarı metni yok." : _result.WarningMessageTemplate)
        </div>
    </div>
}

@code {
    private string _selectedVariant = ModerationVariants.VariantA;
    private bool _running;
    private ModerationInferResult? _result;
    private EChartsInterop? _gaugeEcharts;
    private EChartsInterop? _barEcharts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_result == null) return;
        if (_gaugeEcharts == null)
        {
            await Task.Delay(100);
            await InvokeAsync(async () =>
            {
                if (_gaugeEcharts != null) return;
                _gaugeEcharts = new EChartsInterop(JSRuntime, "moderation-gauge");
                _barEcharts = new EChartsInterop(JSRuntime, "moderation-bar");
                if (await _gaugeEcharts.InitAsync() && await _barEcharts.InitAsync())
                    await UpdateModerationCharts();
                StateHasChanged();
            });
        }
        else
            await UpdateModerationCharts();
    }

    private async Task UpdateModerationCharts()
    {
        if (_result == null) return;
        if (_gaugeEcharts != null)
        {
            var pct = Math.Round(_result.ConfidenceScore * 100, 0);
            await _gaugeEcharts.SetOptionAsync(new
            {
                series = new[]
                {
                    new
                    {
                        type = "gauge",
                        startAngle = 180,
                        endAngle = 0,
                        min = 0,
                        max = 100,
                        progress = new { show = true, width = 18, roundCap = true },
                        detail = new { valueAnimation = true, formatter = "{value}%", offsetCenter = new[] { "0%", "75%" }, fontSize = 18, fontWeight = "bold" },
                        data = new[] { new { value = pct } },
                        axisLine = new { roundCap = true, lineStyle = new { width = 18, color = new object[] { new object[] { 0.3, "#4caf50" }, new object[] { 0.7, "#ff9800" }, new object[] { 1.0, "#d32f2f" } } } },
                        pointer = new { show = false },
                        axisTick = new { show = false },
                        splitLine = new { show = false }
                    }
                }
            });
        }
        if (_barEcharts != null)
        {
            var msgCount = _result.EventsSummary.Count;
            var option = new
            {
                tooltip = new { trigger = "axis" },
                grid = new { left = "3%", right = "4%", bottom = "3%", top = "8%", containLabel = true },
                xAxis = new { type = "category", data = new[] { "Güven %", "Mesaj sayısı", "İzleme (sonraki)" }, axisLine = new { show = true }, splitLine = new { show = false } },
                yAxis = new { type = "value", min = 0, axisLine = new { show = false }, splitLine = new { lineStyle = new { type = "dashed", opacity = 0.4 } } },
                series = new[] { new { type = "bar", data = new object[] { Math.Round(_result.ConfidenceScore * 100, 0), msgCount, _result.ObserveNextCount }, itemStyle = new { color = "#9c27b0" }, barWidth = "50%" } }
            };
            await _barEcharts.SetOptionAsync(option);
        }
    }

    private static string ConfidenceClass(double score)
    {
        if (score >= 0.8) return "high";
        if (score >= 0.5) return "medium";
        return "low";
    }

    private async Task SelectVariant(string v)
    {
        if (_running) return;
        _selectedVariant = v;
        if (_gaugeEcharts != null) { await _gaugeEcharts.DisposeAsync(); _gaugeEcharts = null; }
        if (_barEcharts != null) { await _barEcharts.DisposeAsync(); _barEcharts = null; }
        _result = null;
        StateHasChanged();
    }

    private async Task RunInfer()
    {
        _running = true;
        if (_gaugeEcharts != null) { await _gaugeEcharts.DisposeAsync(); _gaugeEcharts = null; }
        if (_barEcharts != null) { await _barEcharts.DisposeAsync(); _barEcharts = null; }
        _result = null;
        StateHasChanged();
        try
        {
            var baseUri = new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
            var req = new ModerationInferRequest(_selectedVariant);
            var res = await Http.PostAsJsonAsync(baseUri + "/api/moderation/infer", req);
            if (res.IsSuccessStatusCode)
                _result = await res.Content.ReadFromJsonAsync<ModerationInferResult>();
        }
        catch { /* ignore */ }
        _running = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_gaugeEcharts != null) await _gaugeEcharts.DisposeAsync();
        if (_barEcharts != null) await _barEcharts.DisposeAsync();
    }
}
